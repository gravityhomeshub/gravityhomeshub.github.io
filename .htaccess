# ------------------------------------------------------------------
# 🔁 Force www version of gravityhomes.in
# ------------------------------------------------------------------
RewriteEngine On

# Block Known SEO Scrapers, AI Crawlers & Malicious Bots
RewriteCond %{HTTP_USER_AGENT} "PetalBot|Bytespider|MJ12bot|SemrushBot|BLEXBot|YandexBot|Claude|PerplexityBot|GPTBot|OpenAI|Anthropic|crawl|Go-http-client|nbot|Applebot|YisouSpider|Seobility|aiHitBot|Screaming Frog SEO Spider|360Spider|zoominfobot|Dalvik|scanner|scrapy|YandexImages|archive.org_bot|MojeekBot|CCBot|SemrushBot-SI|Apache-HttpClient|netEstate NE Crawler|SurdotlyBot|yak-linkfluence|LWP::Simple|Baiduspider|DuckDuckBot|DotBot|libwww-perl|Offline Explorer|Nautic Expo|Python-urllib|trendiction|TurnitinBot" [NC]
RewriteRule .* - [F,L]

# Block Patterns Matching Generic Bots / Crawlers / AI Scrapers
RewriteCond %{HTTP_USER_AGENT} "spider|scraper|checker|validator|downloader|harvest|leech|agent|java|perl|python|node|siphon|fetch|grabber|seo|ai|link|sitemap|blog|research|feed|survey" [NC]
RewriteRule .* - [F,L]



# Redirect HTTP to HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redirect non-www to www
RewriteCond %{HTTP_HOST} ^gravityhomes\.in [NC]
RewriteRule ^ https://www.gravityhomes.in%{REQUEST_URI} [L,R=301]


AddDefaultCharset UTF-8

# ------------------------------------------------------------------
# ⚙️ General Server Options
# ------------------------------------------------------------------
Options -MultiViews -Indexes
DirectoryIndex index.html

# ------------------------------------------------------------------
# Prevent rewriting of error page
# ------------------------------------------------------------------
RewriteCond %{REQUEST_URI} ^/404\.html$ [NC]
RewriteRule .* - [L]

# ------------------------------------------------------------------
# Legacy URL Redirects
# ------------------------------------------------------------------
RewriteRule ^project/gravity-smera/?$ /project/gravity-smera-gardens [R=301,L]
RewriteRule ^project/gravity-thanisandra/?$ /project/gravity-sky-forest [R=301,L]
RewriteRule ^project/gravity-rajanukunte/?$ /project/gravity-lake-estates [R=301,L]
RewriteRule ^project/gravity-rajankunte/?$ /project/gravity-lake-estates [R=301,L]

# ------------------------------------------------------------------
# Handle deep folder routing
# ------------------------------------------------------------------
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.+[^/])$ /$1/ [R=301,L]

# ------------------------------------------------------------------
# Fallback for missing pages → 404
# ------------------------------------------------------------------
RewriteCond %{REQUEST_URI} !^/404\.html$
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^.*$ /404.html [R=302,L]

# ------------------------------------------------------------------
# Custom 404 error page (commented while rewrite handles it)
# ------------------------------------------------------------------
# ErrorDocument 404 /404.html


# ------------------------------------------------------------------
# Asset Caching Rules
# ------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On

  # Images
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/jpg   "access plus 1 year"
  ExpiresByType image/png   "access plus 1 year"
  ExpiresByType image/gif   "access plus 1 year"
  ExpiresByType image/webp  "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  # Fonts
  ExpiresByType font/woff     "access plus 1 year"
  ExpiresByType font/woff2    "access plus 1 year"
  ExpiresByType font/ttf      "access plus 1 year"
  ExpiresByType font/otf      "access plus 1 year"
  ExpiresByType application/font-woff  "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"

  # CSS and JS
  ExpiresByType text/css              "access plus 1 year"
  ExpiresByType text/javascript       "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"

  # Documents
  ExpiresByType application/pdf "access plus 1 month"

  # Video
  ExpiresByType video/mp4    "access plus 1 year"
  ExpiresByType video/webm   "access plus 1 year"
  ExpiresByType video/mpeg   "access plus 1 year"

  # Fallback
  ExpiresDefault "access plus 2 days"
</IfModule>

<FilesMatch "\.(ico|pdf|jpg|jpeg|png|gif|js|css|svg)$">
  Header set Cache-Control "max-age=3600, public"
</FilesMatch>

<FilesMatch "\.pdf$">
  Header set X-Robots-Tag "noindex, nofollow"
</FilesMatch>

# ------------------------------------------------------------------
# Hotlink Protection
# ------------------------------------------------------------------
# 🔒 Block direct access to image files unless from gravityhomes.in
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Block direct access to images unless Referer is gravityhomes.in
  RewriteCond %{HTTP_REFERER} !^https?://(www\.)?gravityhomes\.in/ [NC]
  RewriteCond %{REQUEST_URI} \.(jpg|jpeg|png|webp|gif|bmp)$ [NC]
  RewriteRule .* - [F]
</IfModule>


# Whitelist Legitimate Crawlers and Previews
SetEnvIfNoCase User-Agent "Googlebot" good_bot
SetEnvIfNoCase User-Agent "Bingbot" good_bot
SetEnvIfNoCase User-Agent "LinkedInBot" good_bot
SetEnvIfNoCase User-Agent "Pinterest" good_bot
SetEnvIfNoCase User-Agent "Twitterbot" good_bot
SetEnvIfNoCase User-Agent "facebookexternalhit" good_bot
SetEnvIfNoCase User-Agent "WhatsApp" good_bot

# Block Known SEO Scrapers, AI Crawlers & Malicious Bots
SetEnvIfNoCase User-Agent "AhrefsBot|PetalBot|Bytespider|MJ12bot|SemrushBot|BLEXBot|YandexBot|Claude|PerplexityBot|GPTBot|OpenAI|Anthropic|crawl|Go-http-client|nbot|Applebot|YisouSpider|Seobility|aiHitBot|Screaming Frog SEO Spider|360Spider|zoominfobot|Dalvik|scanner|scrapy|YandexImages|archive.org_bot|MojeekBot|CCBot|SemrushBot-SI|Apache-HttpClient|netEstate NE Crawler|SurdotlyBot|yak-linkfluence|LWP::Simple|Baiduspider|DuckDuckBot|DotBot|libwww-perl|Offline Explorer|Nautic Expo|Python-urllib|trendiction|TurnitinBot" bad_bot

# Block Patterns Matching Generic Bots / Crawlers / AI Scrapers
SetEnvIfNoCase User-Agent "spider|scraper|checker|validator|downloader|harvest|leech|agent|java|perl|python|node|siphon|fetch|grabber|seo|ai|link|sitemap|blog|research|feed|survey" bad_bot

# 🛡️ Enforcement Logic: Block if NOT Whitelisted
Order Allow,Deny
Allow from all
Deny from env=bad_bot
Allow from env=good_bot



